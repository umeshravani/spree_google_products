<% content_for :page_title do %>
  <div class="flex items-center gap-3">
    <%= image_tag 'app_icons/google_merchant_logo.svg', class: "w-8 h-8", alt: 'Google Merchant Logo' %>
    <span class="text-xl font-bold text-gray-900">
      <%= Spree.t(:google_merchant_dashboard) %>
    </span>
  </div>
<% end %>

<% content_for :page_actions do %>
  <% if @credential&.active? %>
    <%= button_to admin_google_shopping_sync_path, method: :post, class: 'btn btn-primary flex items-center gap-2' do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
      </svg>
      <span>Sync</span>
    <% end %>
  <% else %>
    <button class="btn btn-secondary" disabled>
      Sync Disabled
    </button>
  <% end %>
<% end %>

<div class="card mb-6">
  <div class="card-header flex justify-between items-center">
    <h3 class="card-title">Product Status (Google Shopping)</h3>
    
    <% last_updated = @stats[:last_updated] %>
    <span class="text-sm text-gray-500">
      <% if last_updated && @credential&.active? %>
        Updated <%= time_ago_in_words(last_updated) %> ago
      <% else %>
        Waiting for sync...
      <% end %>
    </span>
  </div>
  
  <div class="card-body p-0">
    <% if @credential&.active? %>
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-gray-100">
        
        <div class="p-6 text-center">
          <div class="text-4xl font-bold text-green-600 mb-1"><%= @stats[:approved] || 0 %></div>
          <div class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 mb-2">
            Approved
          </div>
          <p class="text-xs text-gray-500">Live & Ready to Serve</p>
        </div>

        <div class="p-6 text-center">
          <div class="text-4xl font-bold text-yellow-500 mb-1"><%= @stats[:limited] || 0 %></div>
          <div class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 mb-2">
            Limited
          </div>
          <p class="text-xs text-gray-500">Approved (Partial Visibility)</p>
          <% if (@stats[:limited] || 0) > 0 %>
            <div class="mt-3">
              <%= link_to admin_google_shopping_issues_path, class: "text-primary-600 hover:text-primary-800 text-xs font-semibold inline-flex items-center" do %>
                View Issues 
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3 ml-1">
                  <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                </svg>
              <% end %>
            </div>
          <% end %>
        </div>

        <div class="p-6 text-center">
          <div class="text-4xl font-bold text-red-600 mb-1"><%= @stats[:disapproved] || 0 %></div>
          <div class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 mb-2">
            Not Approved
          </div>
          <p class="text-xs text-gray-500">Critical Issues Detected</p>
          <% if (@stats[:disapproved] || 0) > 0 %>
            <div class="mt-3">
              <%= link_to admin_google_shopping_issues_path, class: "text-red-600 hover:text-red-800 text-xs font-semibold inline-flex items-center" do %>
                View Fixes 
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3 ml-1">
                  <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                </svg>
              <% end %>
            </div>
          <% end %>
        </div>

        <div class="p-6 text-center">
          <div class="text-4xl font-bold text-blue-500 mb-1"><%= @stats[:pending] || 0 %></div>
          <div class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 mb-2">
            Pending
          </div>
          <p class="text-xs text-gray-500">Under Review by Google</p>
        </div>

      </div>
    <% else %>
      <div class="p-8 text-center bg-gray-50">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-gray-400 mx-auto mb-3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
        </svg>
        <h3 class="text-lg font-medium text-gray-900">Connection Required</h3>
        <p class="text-gray-500 mt-1 mb-4">Please connect your Google Account to see live product stats.</p>
        <%= link_to "Connect Now", edit_admin_google_merchant_settings_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">Connection Details</h3>
    </div>
    <div class="card-body">
      <dl class="divide-y divide-gray-100">
        <div class="py-3 flex justify-between">
          <dt class="text-sm font-medium text-gray-500">Merchant Center ID</dt>
          <dd class="text-sm font-medium text-gray-900"><%= @credential&.merchant_center_id || 'Not Set' %></dd>
        </div>

        <div class="py-3 flex justify-between">
          <dt class="text-sm font-medium text-gray-500">Target Country</dt>
          <dd class="text-sm font-medium text-gray-900">
             <% if @credential&.target_country.present? %>
               <%= @credential.target_country %> (<%= @credential.target_currency %>)
             <% else %>
               <span class="text-gray-400">Default (US)</span>
             <% end %>
          </dd>
        </div>

        <div class="py-3 flex justify-between">
          <dt class="text-sm font-medium text-gray-500">Last Synced</dt>
          <dd class="text-sm font-medium text-gray-900">
            <%= @last_sync ? time_ago_in_words(@last_sync) + " ago" : "Never" %>
          </dd>
        </div>
      </dl>

      <div class="mt-6 flex gap-3">
        <%= link_to "Configure", edit_admin_google_merchant_settings_path, class: 'btn btn-primary' %>
        <a href="https://merchants.google.com/" target="_blank" class="btn btn-secondary flex items-center gap-2">
          <span>Open Merchant Center</span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4a.75.75 0 011.5 0v4A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h5a.75.75 0 010 1.5h-5z" clip-rule="evenodd" />
            <path fill-rule="evenodd" d="M6.194 12.753a.75.75 0 001.06.053L16.5 4.44v2.81a.75.75 0 001.5 0v-4.5a.75.75 0 00-.75-.75h-4.5a.75.75 0 000 1.5h2.553l-9.056 8.194a.75.75 0 00-.053 1.06z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h3 class="card-title">Sync Health</h3>
    </div>
    <div class="card-body">
      <p class="text-sm text-gray-500 mb-4">
        Products are automatically synced in the background immediately after you Create or Update them in Spree.
      </p>
      
      <div class="alert alert-info mb-3"><span class="icon icon-info-circle mr-2"></span>Google usually takes 3-5 business days to review newly synced products.</div>

      <p class="text-xs text-gray-400">
        Use the "Sync Now" button at the top right to force a full update for all products immediately.
      </p>
    </div>
  </div>
</div>
